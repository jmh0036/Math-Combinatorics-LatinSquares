#!/usr/bin/env perl -Ilib

use strict;
use warnings;
use Math::Combinatorics::LatinSquares;
use Getopt::Long;
use Pod::Usage;

=head1 NAME

latin-squares - Generate a random latin square with rectangular regional constraints

=head1 SYNOPSIS

    latin-squares --region R C [--region R C ...] [--verbose] [--help]

=head1 DESCRIPTION

Generates a random completed latin square on an NxN grid, where N is the
common product of all specified region dimensions.

Each C<--region R C> describes a complete uniform tiling of the NxN grid by
RxC rectangles.  All tilings are enforced simultaneously: every box from every
tiling must contain each of the N symbols exactly once.

Rows and columns are B<not> assumed.  To include them, add C<--region 1 N>
(rows) and/or C<--region N 1> (columns) explicitly.

=head1 OPTIONS

=over 4

=item B<--region R C>

A rectangular box shape to enforce as a latin regional constraint.  Repeat
to specify multiple simultaneous tilings.  All pairs must have the same
product R*C = N.

=item B<--verbose>

Print each tiling's box map above the solution grid.

=item B<--help>

Show this help message.

=back

=head1 EXAMPLES

    # 9x9 with only 3x3 box constraint (not a full sudoku — no row/col)
    latin-squares --region 3 3

    # Classic 9x9 sudoku (rows + cols + 3x3 boxes)
    latin-squares --region 1 9 --region 9 1 --region 3 3

    # 6x6: both 2x3 and 3x2 box tilings simultaneously (no rows/cols)
    latin-squares --region 2 3 --region 3 2 --verbose

    # 6x6 full sudoku pair latin square: rows, cols, and both box orientations
    latin-squares --region 1 6 --region 6 1 --region 2 3 --region 3 2 --verbose

    # 4x4 with only 2x2 box constraint
    latin-squares --region 2 2

=cut

my @region_args;
my $verbose = 0;
my $help    = 0;

GetOptions(
    'region=i{2}' => \@region_args,
    'verbose'     => \$verbose,
    'help|h'      => \$help,
) or pod2usage(2);

pod2usage(-exitval => 0, -verbose => 2) if $help;
pod2usage(-message => "At least one --region R C is required.\n", -exitval => 2)
    unless @region_args >= 2;

# Parse flat list of pairs from GetOptions
my @regions;
while (@region_args) {
    push @regions, [ splice(@region_args, 0, 2) ];
}

my $ls = eval { Math::Combinatorics::LatinSquares->new(regions => \@regions) };
if ($@) {
    (my $err = $@) =~ s/ at .+ line \d+.*//s;
    die "$err\n";
}

my $N = $ls->n;

if ($verbose) {
    my $specs = $ls->regions;
    my $maps  = $ls->region_maps;
    for my $t (0 .. $#$specs) {
        my ($br, $bc) = @{ $specs->[$t] };
        printf "=== Tiling %d: %dx%d boxes ===\n", $t, $br, $bc;
        $ls->print_region_map($t);
        print "\n";
    }
}

my $grid = $ls->solve;
die "No solution found for this combination of regional constraints.\n"
    unless $grid;

print "=== Solution (${N}x${N}) ===\n" if $verbose;
$ls->print_grid($grid);
